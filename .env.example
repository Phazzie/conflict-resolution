# MixitFixit Environment Configuration

# Application Settings
VITE_APP_NAME=MixitFixit
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# API Configuration
VITE_API_BASE_URL=https://api.mixitfixit.com
VITE_AI_SERVICE_URL=https://ai.mixitfixit.com
VITE_ANALYTICS_URL=https://analytics.mixitfixit.com

# AI Service Settings
VITE_GEMINI_API_KEY=your-gemini-api-key-here
VITE_AI_MODEL=gemini-pro
VITE_AI_MAX_TOKENS=1000
VITE_AI_TEMPERATURE=0.7

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=3600
VITE_RATE_LIMIT_MAX_RETRIES=3

# Security Settings
VITE_ENABLE_CSRF_PROTECTION=true
VITE_ENABLE_XSS_PROTECTION=true
VITE_SECURE_COOKIES=true
VITE_CORS_ORIGIN=https://mixitfixit.com

# Performance Settings
VITE_ENABLE_COMPRESSION=true
VITE_BUNDLE_SIZE_LIMIT=2048
VITE_LAZY_LOADING=true

# Monitoring & Analytics
VITE_ENABLE_ERROR_TRACKING=true
VITE_SENTRY_DSN=your-sentry-dsn-here
VITE_ANALYTICS_TRACKING_ID=your-analytics-id-here

# Feature Flags
VITE_ENABLE_MULTIPLAYER=true
VITE_ENABLE_ML_FEATURES=true
VITE_ENABLE_PREMIUM_FEATURES=false
VITE_ENABLE_DEBUG_PANEL=false

# Session Configuration
VITE_SESSION_TIMEOUT=3600000
VITE_MAX_SESSION_HISTORY=50
VITE_AUTO_SAVE_INTERVAL=30000

# Business Model Settings
VITE_ENABLE_SUBSCRIPTIONS=false
VITE_FREE_SESSIONS_LIMIT=3
VITE_PREMIUM_PRICE_MONTHLY=9.99

# Development Settings (only for dev environment)
VITE_DEV_API_DELAY=0
VITE_DEV_MOCK_API=false
VITE_DEV_SHOW_WARNINGS=true